{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Maven: build",
            "type": "shell",
            "command": "C:\\ProgramData\\chocolatey\\lib\\maven\\apache-maven-3.9.16\\bin\\mvn.cmd",
            "args": ["-DskipTests", "package"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        },
        {
            "label": "Maven: run desktop",
            "type": "shell",
            "command": "C:\\ProgramData\\chocolatey\\lib\\maven\\apache-maven-3.9.16\\bin\\mvn.cmd",
            "args": ["exec:java", "-Dexec.mainClass=com.library.desktop.Main"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            }
        }
    ]
}
